# CarePath Navigator — environment configuration (OPTIONAL)
#
# The app runs FULLY in deterministic "Mock AI Mode" with NO key required.
# These variables only enable the OPTIONAL "Real LLM Mode" for the
# plain-language explanation layer. The deterministic rules engine ALWAYS
# decides the verdict label — an LLM key NEVER changes eligibility logic.
#
# To enable real LLM explanations:
#   1. Copy this file to ".env"
#   2. Fill in a key
#   3. Set VITE_AI_MODE=real
#
# If the key is missing/invalid, the app silently falls back to Mock AI Mode.

VITE_AI_MODE=mock
# VITE_AI_MODE=real

# Anthropic (example provider). The app expects the SAME structured JSON
# shape that Mock AI Mode returns; see src/lib/realLlm.ts.
VITE_ANTHROPIC_API_KEY=
VITE_LLM_MODEL=claude-sonnet-4-6
